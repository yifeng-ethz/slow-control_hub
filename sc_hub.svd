              <bitWidth>31</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ORD_DRAIN_CNT</name>
          <description>Release-drain event counter.</description>
          <addressOffset>0x64</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>value</name>
              <description>Count of release-drain events.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
