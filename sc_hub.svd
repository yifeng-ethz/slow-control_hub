              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>OOO_CTRL</name>
          <description>Runtime out-of-order enable request. Only effective when OOO support is synthesized.</description>
          <addressOffset>0x60</addressOffset>
          <access>read-write</access>
          <fields>
            <field>
              <name>ooo_runtime_enable</name>
              <description>Runtime request to enable out-of-order completion.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
