        <register>
          <name>FEB_TYPE</name>
          <description>Local detector-class selector used by M/S/T packet masking: 0=ALL, 1=MUPIX, 2=SCIFI, 3=TILE.</description>
          <addressOffset>0x70</addressOffset>
          <access>read-write</access>
          <fields>
